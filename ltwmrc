#!/bin/sh
#
# ltwmrc — LTWM configuration script
# Runs async alongside the event loop on startup.
# Reload: ltwmc reload
#

ltwmc() { /usr/local/bin/ltwmc "$@"; }

# ── borders ─────────────────────────────────────────────────
ltwmc config border_width 2
ltwmc config border_active   '#89B4FA'
ltwmc config border_inactive '#45475A'

# ── layout ──────────────────────────────────────────────────
ltwmc config gap 6
ltwmc config master_ratio 0.55

# ── floating window default size ────────────────────────────
ltwmc config float_default_w 900
ltwmc config float_default_h 600

# ── workspace names ──────────────────────────────────────────
ltwmc config workspace_name '1 I'
ltwmc config workspace_name '2 II'
ltwmc config workspace_name '3 III'
ltwmc config workspace_name '4 IV'
ltwmc config workspace_name '5 V'
ltwmc config workspace_name '6 VI'
ltwmc config workspace_name '7 VII'
ltwmc config workspace_name '8 VIII'
ltwmc config workspace_name '9 IX'
ltwmc config workspace_name '10 X'

# ── bar ─────────────────────────────────────────────────────
# Set ALL bar config first, then call bar_commit to create bar in one shot.
# This prevents partial config flash (wrong font/color on startup).
#
# To use native bar: bar_enable 1, comment out polybar in autostart.
# To use polybar:    bar_enable 0, keep polybar in autostart.

ltwmc config bar_enable 1
ltwmc config bar_height 28
ltwmc config bar_padding_x 6
ltwmc config bar_font 'JetBrains Mono:size=12'

# read pywal colors if available, fall back to catppuccin mocha
. "${HOME}/.cache/wal/colors.sh" 2>/dev/null || true
ltwmc config bar_bg             "${color0:-#1E1E2E}"
ltwmc config bar_fg             "${foreground:-#CDD6F4}"
ltwmc config bar_ws_active_bg   "${color4:-#89B4FA}"
ltwmc config bar_ws_active_fg   "${color0:-#1E1E2E}"
ltwmc config bar_ws_occupied_bg "${color8:-#313244}"
ltwmc config bar_ws_occupied_fg "${foreground:-#CDD6F4}"

ltwmc config bar_show_layout  1
ltwmc config bar_show_version 0

# right-side commands
ltwmc config bar_clear_cmds
ltwmc config bar_cmd_sep ' | '
ltwmc config bar_add_cmd 'iwgetid -r 2>/dev/null || echo "--"'
ltwmc config bar_add_cmd 'amixer get Master 2>/dev/null | grep -oP "\d+(?=%)" | tail -1 | sed "s/^/vol: /"'
ltwmc config bar_add_cmd 'cat /sys/class/power_supply/BAT0/capacity 2>/dev/null | sed "s/$/%/" || true'
ltwmc config bar_add_cmd 'date "+%H:%M  %a %d/%m"'

# create bar now — all config above is applied before window appears
ltwmc config bar_commit

# ── polybar IPC (when bar_enable 0) ─────────────────────────
# Set polybar_pipe to your MODULE NAME — ltwm pushes hook directly to polybar socket.
# ltwmc config polybar_pipe "ltwm-workspaces"

# ── autostart ────────────────────────────────────────────────
# ltwm event loop is already running — & works fine here.
#sxhkd &
#ltwm-bar &         # standalone bar — reads state from ltwm IPC
# polybar &       # alternative: use polybar with internal/xworkspaces
